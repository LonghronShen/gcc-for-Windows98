diff --git a/gcc/diagnostic-color.c b/gcc/diagnostic-color.c
index 1fc5a9079..7c000be35 100644
--- a/gcc/diagnostic-color.c
+++ b/gcc/diagnostic-color.c
@@ -22,7 +22,14 @@
 #include "diagnostic-url.h"
 
 #ifdef __MINGW32__
+/* msxml.h (pulled in via windows.h -> urlmon.h) declares COM methods named
+   'abort', which clash with GCC's '#define abort() fancy_abort(...)' from
+   system.h.  Temporarily suppress the macro while processing Windows SDK
+   headers, then restore it afterwards.  */
+#pragma push_macro("abort")
+#undef abort
 #  include <windows.h>
+#pragma pop_macro("abort")
 #endif
 
 #include "color-macros.h"
